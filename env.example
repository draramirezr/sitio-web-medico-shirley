# ============================================
# CONFIGURACIÓN DE EMAIL
# ============================================
# 
# IMPORTANTE: 
# 1. Copia este archivo como ".env" (sin el .example)
# 2. Reemplaza los valores con tus credenciales reales
# 3. NUNCA compartas el archivo .env con nadie
#
# ============================================

# Email desde donde se enviarán las notificaciones
EMAIL_USERNAME=dra.ramirezr@gmail.com

# Contraseña de aplicación de Gmail (NO tu contraseña normal)
# IMPORTANTE: NUNCA subas este archivo con contraseñas reales a Git
# Para generarla: https://myaccount.google.com/apppasswords
# Debes tener activada la verificación en 2 pasos
EMAIL_PASSWORD=

# Email que recibirá las notificaciones
EMAIL_DESTINATARIO=dra.ramirezr@gmail.com

# Configuración del servidor SMTP
# (SendGrid sigue activo en producción vía SENDGRID_API_KEY en app_simple.py)
#
# --- ZOHO MAIL (recomendado si el correo está en Zoho) ---
# Servidor SMTP:     smtp.zoho.com  (dominio org.: smtppro.zoho.com)
# Puerto TLS:        587  → EMAIL_USE_TLS=True,  EMAIL_USE_SSL=False
# Puerto SSL:        465  → EMAIL_USE_TLS=False, EMAIL_USE_SSL=True
# Autenticación:     Sí (EMAIL_USERNAME + contraseña de aplicación Zoho)
#
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_USERNAME=info@draramirezr.com
EMAIL_PASSWORD=
#
# --- Gmail (alternativa) ---
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False

# ============================================
# CÓMO OBTENER LA CONTRASEÑA:
# ============================================
# 1. Ve a: https://myaccount.google.com/
# 2. Click en "Seguridad"
# 3. Activa "Verificación en 2 pasos" (si no está activa)
# 4. Click en "Contraseñas de aplicaciones"
# 5. Selecciona "Correo" y "Otro"
# 6. Dale un nombre: "Sitio Web"
# 7. Copia la contraseña de 16 caracteres
# 8. Pégala arriba en EMAIL_PASSWORD (sin espacios)
#
# Ejemplo:
# EMAIL_PASSWORD=abcdefghijklmnop
# ============================================

# ============================================
# PROVEEDORES DE EMAIL ALTERNATIVOS:
# ============================================
# 
# SENDGRID (100 emails gratis/día):
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USERNAME=apikey
# EMAIL_PASSWORD=tu_api_key_de_sendgrid
# EMAIL_USE_TLS=True
#
# MAILGUN:
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USERNAME=postmaster@tu-dominio.mailgun.org
# EMAIL_PASSWORD=tu_password_mailgun
# EMAIL_USE_TLS=True
#
# OUTLOOK/HOTMAIL:
# EMAIL_HOST=smtp-mail.outlook.com
# EMAIL_PORT=587
# EMAIL_USERNAME=tu_email@outlook.com
# EMAIL_PASSWORD=tu_contraseña
# EMAIL_USE_TLS=True
#
# ZOHO MAIL — resumen oficial:
#   Servidor SMTP: smtp.zoho.com  (org. con dominio: smtppro.zoho.com)
#   Puerto SSL:    465  (EMAIL_USE_SSL=True,  EMAIL_USE_TLS=False)
#   Puerto TLS:    587  (EMAIL_USE_TLS=True,  EMAIL_USE_SSL=False)
#   Autenticación: Sí
#   Contraseña:    https://accounts.zoho.com/home#security/app_password
#   Prueba:        python test_email_smtp.py
# ============================================

# ============================================
# GOOGLE ADS - CONVERSIÓN WHATSAPP
# ============================================
# ID de cuenta (Google Ads > Herramientas > Conversiones > Etiqueta del sitio web)
GOOGLE_ADS_ID=AW-11017749694
# Etiqueta de conversión (solo el sufijo después de la barra /)
GOOGLE_ADS_CONVERSION_LABEL=JjDCCIXU140cEL6J1oUp
# Resultado en el sitio: AW-11017749694/JjDCCIXU140cEL6J1oUp
# (Acción "Contacto" en Google Ads — no confundir con otras etiquetas de conversión)
